# --- General ---
.DS_Store
.env
.env.*
!.env.example
*.log
dist/
dist-ssr/
*.local

# --- Pardploy Data (SQLite & Persistent) ---
# Ignoramos la base de datos local y archivos temporales de SQLite
data/*
!data/.gitkeep

# --- Rust (Backend) ---
backend/target/
# En aplicaciones finales se suele subir el lock, pero en desarrollo 
# constante de orquestadores a veces se prefiere ignorar si cambias mucho de entorno.
# Descomenta la siguiente línea si prefieres no subirlo:
# backend/Cargo.lock
backend/**/core
backend/**/*.bk

# --- Bun/UI (Frontend en ui/web) ---
ui/web/node_modules/
ui/web/dist/
ui/web/.bash_history
ui/web/bun.lockb
ui/web/npm-debug.log*
ui/web/yarn-debug.log*
ui/web/yarn-error.log*

# --- IDEs & Editors (Vim/Nvim/VSCode) ---
.vscode/
.idea/
*.swp
*.swo
.zed/
*~

# --- Docker ---
.docker/
